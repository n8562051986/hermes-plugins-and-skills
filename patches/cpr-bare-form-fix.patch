 # Some terminals/filters can drop ESC and literal "^[[", leaving only
@@ -2772,11 +2780,25 @@ def _bind_prompt_submit_keys(kb, handler) -> None:
 
 
 def _disable_prompt_toolkit_cpr_warning(app) -> None:
-    """Let prompt_toolkit fall back from CPR without printing into the prompt."""
+    """Let prompt_toolkit fall back from CPR without printing into the prompt.
+
+    Also disables CPR queries entirely (``enable_cpr=False``) so that
+    prompt_toolkit never sends ``ESC[6n`` to the terminal.  Under ConPTY
+    / WSL the terminal's ``ESC[<row>;<col>R`` response can race past the
+    input parser and land as visible text (see issue #23350).  Preventing
+    the query is cleaner than trying to strip the leaked response from
+    both the input buffer and the rendered output.
+    """
     try:
         app.renderer.cpr_not_supported_callback = None
     except Exception:
         pass
+    try:
+        out = app.renderer.output
+        if hasattr(out, 'enable_cpr'):
+            out.enable_cpr = False
+    except Exception:
+        pass
 
 
