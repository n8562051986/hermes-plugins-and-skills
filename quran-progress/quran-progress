# ── Storage ──────────────────────────────────────────────────
def load_data():
    if not os.path.exists(DATA_FILE):
        return {"users": {}, "history": {}}
    with open(DATA_FILE, "r", encoding="utf-8") as f:
        return json.load(f)

def save_data(data):
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

# ── Parser ───────────────────────────────────────────────────
def parse_line(line):
    """
    Parse satu baris progress Quran.

    Format yang didukung:

    1) Simple:    [emoji] D : H204 J27
    2) Full:      [emoji] T 3. Ali Imran: 93 H26 J3
    3) Full var:  [emoji] R 18. Al Kahfi : 016 H110 J015
    4) Gabung:    [emoji] ZM 7. Al A'raf : 001 H061 J08

    Return dict atau None.
    """
    line = line.strip()
    if not line or line.startswith("```") or line.startswith("˗ˏˋ"):
        return None

    # ── Step 1: Cari awal inisial (ASCII letter) ──
    m = re.search(r"[A-Za-z]", line)
    if not m:
        return None
    line = line[m.start():]

    # ── Step 2: Ekstrak inisial ──
    m = re.match(r"([A-Za-z]+)", line)
    if not m:
        return None
    initials = m.group(1).upper()
    rest = line[m.end():].strip()

    # ── Step 3: Cari H dan J sebagai anchor ──
    h_match = re.search(r"H\s*(\d+)", rest)
    j_match = re.search(r"J\s*(\d+)", rest)

    page = int(h_match.group(1)) if h_match else None
    juz = int(j_match.group(1)) if j_match else None

    if not page and not juz:
        return None  # minimal harus ada salah satu

    # ── Step 4: Parse middle section (antara inisial dan H) ──
    surah_no = None
    surah_name = None
    ayat = None

    # Potong bagian sebelum H untuk parsing surah
    if h_match:
        middle = rest[:h_match.start()].strip().rstrip(":")
    elif j_match:
        middle = rest[:j_match.start()].strip().rstrip(":")
    else:
        middle = ""

    if middle:
        # Cari "surah_no. surah_name: ayat" atau "surah_no. surah_name ayat"
        # Pattern: angka. teks : angka
        m_surah = re.search(
            r"(\d+)\s*\.\s*(.+?)(?:\s*:\s*(\d+))?\s*$",
            middle
        )
        if m_surah:
            surah_no = int(m_surah.group(1))
            surah_name = m_surah.group(2).strip()
            ayat = int(m_surah.group(3)) if m_surah.group(3) else None

            # Normalisasi nama surah dari daftar resmi
            if surah_no in SURAH_LIST:
                surah_name = SURAH_LIST[surah_no]

    return {
        "initials": initials,
        "surah_no": surah_no,
        "surah_name": surah_name,
        "ayat": ayat,
        "page": page,
        "juz": juz,
    }


# ── Actions ──────────────────────────────────────────────────
def cmd_add(lines):
    """Parse dan simpan satu atau lebih baris progress."""
    data = load_data()
    now = datetime.now().isoformat()
    results = []

    for line in lines:
        parsed = parse_line(line)
        if not parsed:
            results.append((line.strip(), None, "Tidak bisa diparse"))
            continue

        initials = parsed["initials"]

        # Update user progress terbaru
        data.setdefault("users", {})[initials] = {
            "last_update": now,
            "surah_no": parsed["surah_no"],
            "surah_name": parsed["surah_name"],
            "ayat": parsed["ayat"],
            "page": parsed["page"],
            "juz": parsed["juz"],
        }

        # Tambah ke history
        data.setdefault("history", {}).setdefault(initials, []).append({
            "timestamp": now,
            "surah_no": parsed["surah_no"],
            "surah_name": parsed["surah_name"],
            "ayat": parsed["ayat"],
            "page": parsed["page"],
            "juz": parsed["juz"],
            "raw": line.strip(),
        })

        # Cek delta dari entry sebelumnya
        history = data["history"][initials]
        delta_str = ""
        if len(history) >= 2:
            prev = history[-2]
            delta = _compute_delta(parsed, prev)
            if delta:
                delta_str = f"  (+{', '.join(delta)})"

        parts = []
        if parsed["surah_name"]:
            parts.append(f"{parsed['surah_no']}. {parsed['surah_name']}")
        if parsed["ayat"]:
            parts.append(f"ayat {parsed['ayat']}")
        if parsed["page"]:
            parts.append(f"H{parsed['page']}")
        if parsed["juz"]:
            parts.append(f"J{parsed['juz']}")

        summary = f"  {initials}: {' — '.join(parts)}{delta_str}"
        results.append((line.strip(), parsed, summary))

    save_data(data)

    # Output
    for raw, parsed, summary in results:
        if parsed:
            print(f"✓ {summary}")
        else:
            print(f"✗ {raw} — {summary}")


def _compute_delta(current, previous):
    """Hitung perubahan dari sebelumnya."""
    if not previous:
        return None
    deltas = []
    if current.get("juz") and previous.get("juz"):
        if current["juz"] > previous["juz"]:
            d = current["juz"] - previous["juz"]
            deltas.append(f"{d} Juz")
    if current.get("surah_no") and previous.get("surah_no"):
        if current["surah_no"] > previous["surah_no"]:
            d = current["surah_no"] - previous["surah_no"]
            deltas.append(f"{d} Surah")
    if current.get("ayat") and previous.get("ayat"):
        if current["surah_no"] == previous.get("surah_no") and current.get("ayat", 0) > previous.get("ayat", 0):
            d = current["ayat"] - previous["ayat"]
            deltas.append(f"{d} Ayat")
    if current.get("page") and previous.get("page"):
        if current["page"] > previous["page"]:
            d = current["page"] - previous["page"]
            deltas.append(f"{d} Halaman")
    return deltas if deltas else None


def cmd_list():
    """Tampilkan progress terkini semua user."""
    data = load_data()
    users = data.get("users", {})
    if not users:
        print("Belum ada data. Gunakan: quran-progress add \"...\"")
        return

    print(f"{'Inisial':<10} {'Surah':<22} {'Ayat':<8} {'Hal':<6} {'Juz':<4}  Terakhir Update")
    print("-" * 80)
    for initials in sorted(users.keys()):
        u = users[initials]
        surah = f"{u.get('surah_no', '')}. {u.get('surah_name', '')}" if u.get('surah_name') else "-"
        ayat = str(u.get('ayat', '')) if u.get('ayat') else "-"
        page = str(u.get('page', '')) if u.get('page') else "-"
        juz = str(u.get('juz', '')) if u.get('juz') else "-"
        ts = u.get('last_update', '')[:16]
        print(f"{initials:<10} {surah:<22} {ayat:<8} {page:<6} {juz:<4}  {ts}")


def cmd_report():
    """Ringkasan sederhana."""
    data = load_data()
    users = data.get("users", {})
    if not users:
        print("Belum ada data.")
        return

    print("=== Ringkasan Progress Quran ===\n")
    for initials in sorted(users.keys()):
        u = users[initials]
        parts = []
        if u.get("surah_name"):
            parts.append(f"{u['surah_no']}. {u['surah_name']}")
        if u.get("ayat"):
            parts.append(f"ayat {u['ayat']}")
        if u.get("page"):
            parts.append(f"Halaman {u['page']}")
        if u.get("juz"):
            parts.append(f"Juz {u['juz']}")
        else:
            parts.append("(belum ada data)")

        # Hitung total laporan
        history = data.get("history", {}).get(initials, [])
        report_count = len(history)

        print(f"  {initials}: {' — '.join(parts)}")
        print(f"           Total laporan: {report_count}x")
        print()


def cmd_history(initials):
    """Tampilkan riwayat per orang."""
    data = load_data()
    initials = initials.upper()
    history = data.get("history", {}).get(initials, [])

    if not history:
        print(f"Belum ada riwayat untuk {initials}.")
        return

    print(f"Riwayat {initials} ({len(history)} laporan):")
    print("-" * 70)
    for i, entry in enumerate(history, 1):
        ts = entry.get("timestamp", "")[:16]
        parts = []
        if entry.get("surah_name"):
            parts.append(f"{entry['surah_no']}. {entry['surah_name']}")
        if entry.get("ayat"):
            parts.append(f"ayat {entry['ayat']}")
        if entry.get("page"):
            parts.append(f"H{entry['page']}")
        if entry.get("juz"):
            parts.append(f"J{entry['juz']}")
        print(f"  {i:>2}. [{ts}] {' — '.join(parts)}")

        # Delta dari sebelumnya
        if i > 1:
            delta = _compute_delta(entry, history[i-2])
            if delta:
                print(f"      ▲ {', '.join(delta)}")


# ── Main ─────────────────────────────────────────────────────
def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "add":
        if not sys.stdin.isatty():
            # Pipe mode: baca dari stdin
            lines = [l for l in sys.stdin if l.strip()]
            if lines:
                cmd_add(lines)
            else:
                print("Tidak ada input dari stdin.")
        elif len(sys.argv) >= 3:
            cmd_add([" ".join(sys.argv[2:])])
        else:
            print("Usage: quran-progress add \"<text>\"")
            print("       echo \"<text>\" | quran-progress add")
            sys.exit(1)

    elif cmd == "list":
        cmd_list()

    elif cmd == "report":
        cmd_report()

    elif cmd == "history":
        if len(sys.argv) < 3:
            print("Usage: quran-progress history <inisial>")
            sys.exit(1)
        cmd_history(sys.argv[2])

    else:
        print(f"Perintah tidak dikenal: {cmd}")
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
