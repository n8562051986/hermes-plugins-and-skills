#!/usr/bin/env python3
"""
quran-progress — CLI tracker for Quran reading progress.
Zero AI dependency. Pure Python + JSON storage.

Usage:
  quran-progress add "🌼D : H204 J27"
  quran-progress add "👱‍♂️T 03. Ali Imran: 093 H026 J03"
  quran-progress add < lines.txt          — pipe/redirect from stdin
  quran-progress list                     — semua data tersimpan
  quran-progress report                   — ringkasan progres
  quran-progress history <inisial>        — riwayat per orang
"""

import json
import os
import re
import sys
from datetime import datetime

# ── Konfigurasi ──────────────────────────────────────────────
